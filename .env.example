# Copy this file to ".env" and fill in your own Supabase project values.
# Find them in your Supabase dashboard → Project Settings → API.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_KEY=sb_publishable_YOUR_PUBLISHABLE_KEY

# Mapbox — public access token (safe in the browser). Get a free one at
# https://account.mapbox.com/access-tokens/ . Starts with "pk."
VITE_MAPBOX_TOKEN=pk.YOUR_MAPBOX_PUBLIC_TOKEN

# ── Payments (Stripe) — set these as SUPABASE FUNCTION SECRETS, not here. ──
# See PAYMENTS_SETUP.md. Listed for reference only:
#   STRIPE_SECRET_KEY=sk_test_...
#   STRIPE_PRICE_STARTER=price_...
#   STRIPE_PRICE_GROWTH=price_...
#   STRIPE_PRICE_PREMIUM=price_...
#   STRIPE_WEBHOOK_SECRET=whsec_...
